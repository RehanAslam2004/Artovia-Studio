rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.matches('.*@artoviastudio[.]com') || 
         request.auth.token.email == 'admin@example.com' ||
         // Add your specific admin email here if different
         request.auth.token.email == 'artovia.business@gmail.com'); 
    }

    // Products: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: 
    // - Create: Public (for guest checkout)
    // - Read: Own orders or Admin
    // - Update: Admin only (for status updates)
    match /orders/{orderId} {
      allow create: if true;
      // Allow anyone with the ID (UUID) to read the order (needed for download page)
      allow get: if true;
      // Only admins or owners can list orders
      allow list: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
    }

    // Guest Carts: Public read/write (needed for the sync feature)
    // Warning: This is permissive, but needed for the feature to work without auth.
    // Ideally, we'd use anonymous auth, but for now we'll scope it by email/ID.
    match /guest_carts/{cartId} {
      allow read, write: if true; 
    }

    // User Carts: Authenticated users can read/write their own cart
    match /carts/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Reviews: Public read, Authenticated write
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true; // Allow guests to review? Or strictly auth? Let's say true for now.
      allow update, delete: if isAdmin();
    }
    
    // Users: Users can read/write their own data, Admin can read all
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId;
      // Allow admin to update points
      allow update: if isAdmin();
    }

    // Points Transactions: Users read their own, Admin read/write all
    match /points_transactions/{transactionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Settings (rewards config, etc): Public read, Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Connection Test (for debugging)
    match /connection_test/{docId} {
        allow read, write: if true;
    }
  }
}
